# ---- Database ----
# Heslo k Postgres — generuj: openssl rand -base64 24 | tr -d '/+='
DB_PASSWORD=CHANGE_ME

# Lokální vývoj: sahá na localhost Postgres; v produkci compose staví DATABASE_URL z DB_PASSWORD.
DATABASE_URL=postgresql://raseliniste:CHANGE_ME@localhost:5432/raseliniste

# ---- Session / auth ----
# Generuj: openssl rand -base64 48
SESSION_SECRET=CHANGE_ME_AT_LEAST_32_CHARS_LONG_RANDOM

# ---- Gemini ----
# https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# ---- App ----
APP_URL=https://www.raseliniste.cz

# ---- První admin user (použije prisma/seed) ----
ADMIN_USERNAME=Gideon
# Generuj: openssl rand -base64 18 | tr -d '/+=' | cut -c1-20
ADMIN_PASSWORD=CHANGE_ME

# ---- Email (Resend) ----
# https://resend.com → API Keys. Zdarma 3 000 mailů / měsíc.
# Bez klíče mailer jen loguje (systém nepadá).
RESEND_API_KEY=
# From musí být z ověřené domény v Resend (v dashboardu přidat DNS záznamy pro raseliniste.cz).
NOTIFICATION_FROM=reports@raseliniste.cz
# Kam posílat měsíční health reporty a případné další notifikace.
NOTIFICATION_EMAIL=petr@example.cz

# ---- Cron ----
# Shared secret pro /api/cron/* endpointy. Generuj: openssl rand -base64 32
# Synology Task Scheduler ho pošle v hlavičce `x-cron-key`.
CRON_SECRET=CHANGE_ME_CRON_SECRET
