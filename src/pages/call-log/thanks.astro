---
import Base from "../../layouts/Base.astro";
---

<Base
  title="Vzkaz odeslán"
  appleTitle="Vzkaz Gideonovi"
  appleCapable={true}
>
  <div class="min-h-screen grid place-items-center px-4 relative z-10">
    <div class="w-full max-w-sm text-center">
      <div class="glass-strong rounded-xl p-8">
        <div class="text-5xl mb-4">✓</div>
        <h1 class="font-serif text-3xl tracking-tight mb-3">Vzkaz doručen</h1>
        <p class="text-sm text-muted-foreground leading-relaxed">
          Gideon se ti ozve, jakmile vyjde z hluboké práce.
          <br />
          Pokud je to opravdu akutní, zavolej ještě jednou.
        </p>
      </div>
    </div>
  </div>
</Base>
