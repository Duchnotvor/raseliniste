---
import Base from "../layouts/Base.astro";
import LoginForm from "../components/LoginForm";
import { readSession } from "../lib/session";

const session = await readSession(Astro.cookies);
if (session) return Astro.redirect("/");
---

<Base title="Přihlášení">
  <div class="min-h-screen grid place-items-center px-4 relative z-10">
    <div class="w-full max-w-sm">
      <div class="mb-7 text-center">
        <h1 class="font-serif text-5xl tracking-tight">Rašeliniště</h1>
        <div class="mt-2 text-[10px] uppercase tracking-[0.22em] text-muted-foreground font-mono">
          osobní systém
        </div>
      </div>

      <div class="glass-strong rounded-xl p-6">
        <LoginForm client:load />
      </div>

      <p class="mt-6 text-center text-[11px] text-muted-foreground font-mono tracking-wider">
        chráněno heslem + passkey
      </p>
    </div>
  </div>
</Base>
