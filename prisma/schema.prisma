generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
  runtime  = "nodejs"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                String   @id @default(cuid())
  username          String   @unique
  passwordHash      String
  createdAt         DateTime @default(now())
  lastLoginAt       DateTime?

  // Preferences (konfigurovatelné z /settings)
  notificationEmail String?  // kam posílat health reporty; fallback na env NOTIFICATION_EMAIL

  sessions     Session[]
  passkeys     WebauthnCredential[]
  recordings   Recording[]
  apiTokens    ApiToken[]
  healthMetrics HealthMetric[]
  healthEcgs    HealthEcg[]
  healthAnalyses HealthAnalysis[]
  contacts      Contact[]
  callLogs      CallLog[]
  integrations  UserIntegration[]
}

model WebauthnCredential {
  id              String    @id @default(cuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  credentialId    String    @unique // base64url
  publicKey       Bytes
  counter         BigInt    @default(0)
  transports      String[]  // ["internal", "hybrid", "usb", ...]
  deviceType      String    // "singleDevice" | "multiDevice"
  backedUp        Boolean
  nickname        String?
  createdAt       DateTime  @default(now())
  lastUsedAt      DateTime?

  @@index([userId])
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  ip        String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

// ---- Capture: ingest → klasifikace → triage ----

model Recording {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id])

  source          RecordingSource
  rawText         String

  processedAt     DateTime?
  processingError String?

  createdAt       DateTime @default(now())

  entries         Entry[]

  @@index([userId, createdAt])
}

model Entry {
  id               String      @id @default(cuid())
  recordingId      String
  recording        Recording   @relation(fields: [recordingId], references: [id], onDelete: Cascade)

  type             EntryType
  text             String
  rawExcerpt       String?

  // Pouze pro TASK
  suggestedProject String?
  suggestedWhen    TaskWhen?
  rationale        String?

  // Pouze pro KNOWLEDGE
  knowledgeCategory String?
  knowledgeUrl      String?
  knowledgeTags     String[] @default([])

  // Obecné hashtagy (teď hlavně pro JOURNAL po AI redakci)
  hashtags          String[] @default([])

  // Volitelná lokace odkud byl záznam pořízen (GPS z iPhone Shortcutu).
  // JSON: { lat: number, lng: number, name?: string, accuracy?: number }
  location          Json?

  status           EntryStatus @default(PENDING)

  createdAt        DateTime    @default(now())
  confirmedAt      DateTime?

  @@index([recordingId])
  @@index([status])
}

// ---- Zdravotní data (Apple Health přes Health Auto Export) ----

model HealthMetric {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])

  // Typ metriky = přesný název z HAE (step_count, weight_body_mass,
  // blood_pressure, sleep_analysis, heart_rate_variability, ...)
  type        String
  recordedAt  DateTime
  source      String   // "Petr – Apple Watch|Pacer" apod.
  unit        String?  // "kg", "count", "count/min", "kJ", "mmHg", "hr", ...

  // 14 z 17 metrik = simple scalar (step_count, weight, HRV, kroky, ...)
  qty         Float?

  // blood_pressure special-case
  bpSystolic  Float?
  bpDiastolic Float?

  // sleep_analysis: core/deep/rem/awake/asleep/inBed a časové rozsahy
  // — heterogenní pole, ukládáme jako JSONB pro fulltext/analýzu později.
  sleepData   Json?

  // Raw HAE položka (pro pozdější recovery kdyby se měnila schema).
  raw         Json?

  createdAt   DateTime @default(now())

  // ==== Unique constraint proti duplicitám ====
  // Jeden zdravotní záznam je definovaný trojicí (typ, čas, zdroj).
  // HAE tenhle tuple drží napříč exporty, takže re-ingest je bezpečný.
  @@unique([userId, type, recordedAt, source])
  @@index([userId, type, recordedAt])
}

model HealthAnalysis {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id])

  periodFrom      DateTime
  periodTo        DateTime
  focus           String?
  trigger         AnalysisTrigger @default(MANUAL)

  text            String   // markdown odpověď z Gemini
  model           String   // "gemini-2.5-pro"
  promptChars     Int?
  totalSamples    Int?
  metricsWithData Int?

  emailSentAt     DateTime?
  emailError      String?

  createdAt       DateTime @default(now())

  @@index([userId, createdAt])
  @@index([userId, periodFrom, periodTo])
}

enum AnalysisTrigger {
  MANUAL
  MONTHLY_AUTO
}

model HealthEcg {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id])

  startedAt      DateTime
  source         String
  classification String?  // "sinusRhythm", "atrialFibrillation", ...
  averageHr      Float?

  // Voltage samples jsou velké pole (10k+ bodů) — JSONB se komprimuje líp
  // než samostatná tabulka, queries na EKG raw data dělat nebudeme.
  voltageData    Json
  symptoms       Json?

  raw            Json?
  createdAt      DateTime @default(now())

  @@unique([userId, startedAt, source])
  @@index([userId, startedAt])
}

// ---- Gideonův Firewall: kontakty + call-log + integrace ----

model Contact {
  id           String         @id @default(cuid())
  userId       String
  user         User           @relation(fields: [userId], references: [id])

  displayName  String
  firstName    String?
  lastName     String?
  note         String?
  isVip        Boolean        @default(false)

  importedFrom String?        // "vcard" | "manual"
  externalId   String?        // UID z vCard, pokud má

  phones       Phone[]
  emails       ContactEmail[]
  callLogs     CallLog[]

  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@index([userId])
  @@index([userId, isVip])
}

model Phone {
  id        String  @id @default(cuid())
  contactId String
  contact   Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  number    String  // normalizovaný E.164 např. "+420777123456"
  label     String? // "mobile" | "work" | "home" | "other"

  @@unique([contactId, number])
  @@index([number]) // rychlé lookup při příchozím hovoru
}

model ContactEmail {
  id        String  @id @default(cuid())
  contactId String
  contact   Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  email     String
  label     String?

  @@unique([contactId, email])
}

model CallLog {
  id           String    @id @default(cuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id])

  phoneNumber  String    // normalizovaný E.164 tak jak přišel
  rawNumber    String    // jak skutečně přišel z URL (pro audit)
  contactId    String?
  contact      Contact?  @relation(fields: [contactId], references: [id])

  message      String
  isUrgent     Boolean   @default(false)
  wasVip       Boolean   @default(false) // snapshot v době přijetí

  ip           String?
  userAgent    String?

  todoistTaskId    String? // ID v Todoist pokud se podařilo vytvořit
  todoistProjectId String?
  todoistError     String? // pokud push selhal

  mailSentAt   DateTime? // kdy byl odeslán email Gideonovi
  mailError    String?

  seenAt       DateTime? // Gideon označil jako vyřízené

  createdAt    DateTime  @default(now())

  @@index([userId, createdAt])
  @@index([userId, seenAt])
}

model UserIntegration {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])

  provider   String   // "todoist" | budoucí "superlist" | "plaud" atd.

  // Encrypted credentials (AES-256-GCM, klíč odvozen ze SESSION_SECRET)
  tokenEnc   String   // ciphertext v base64
  tokenIv    String   // IV v base64
  tokenTag   String   // auth tag v base64

  // Per-provider konfigurace (pro Todoist: { vyruseni: projectId, vip: projectId })
  config     Json?

  lastUsedAt DateTime?
  lastError  String?

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([userId, provider])
}

model ApiToken {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id])

  name        String
  tokenHash   String    @unique
  prefix      String

  lastUsedAt  DateTime?
  revokedAt   DateTime?
  createdAt   DateTime  @default(now())

  @@index([userId])
  @@index([tokenHash])
}

enum RecordingSource {
  SHORTCUT
  WEB
  MANUAL
}

enum EntryType {
  TASK
  JOURNAL
  THOUGHT
  CONTEXT
  KNOWLEDGE
}

enum TaskWhen {
  TODAY
  THIS_WEEK
  SOMEDAY
}

enum EntryStatus {
  PENDING
  CONFIRMED
  DISCARDED
}

model LoginAttempt {
  id        String   @id @default(cuid())
  username  String
  ip        String
  success   Boolean
  createdAt DateTime @default(now())

  @@index([username, createdAt])
  @@index([ip, createdAt])
}
